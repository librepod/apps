# WG-Easy Configuration (generic defaults)
# Environment-specific overrides go in overlays/librepod/

INIT_HOST=localhost
TZ=UTC

# v15 Unattended Setup (only used on first start)
INIT_ENABLED=true
INIT_USERNAME=admin
INIT_PORT=51820
INIT_DNS=10.43.0.10
INIT_IPV4_CIDR=10.6.0.0/24
INIT_IPV6_CIDR=

# v15 Optional Configuration
INSECURE=true
DISABLE_IPV6=true
