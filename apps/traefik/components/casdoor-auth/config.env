# Casdoor endpoint URL (e.g., http://casdoor.casdoor.svc.cluster.local:8000)
CASDOOR_ENDPOINT=http://sso.libre.pod

# Casdoor organization name
CASDOOR_ORGANIZATION=librepod

# Casdoor application name
CASDOOR_APPLICATION=default

# OAuth callback URL (e.g., https://git.libre.pod/callback)
CALLBACK_URL=http://sso.libre.pod/callback
