# Happy Server Environment Configuration
NODE_ENV=production
PORT=3005
# Database connection URL (set in secret for security)
DATABASE_URL=postgresql://postgres:postgres@happy-postgres:5432/happy-server
SEED=your-seed-for-token-generation

# Metrics configuration
METRICS_ENABLED=true
METRICS_PORT=9090

# Redis connection (references internal redis service)
REDIS_URL=redis://happy-redis:6379

# S3 storage configuration (MinIO)
S3_HOST=happy-minio
S3_PORT=9000
S3_BUCKET=happy-files
S3_PUBLIC_URL=http://happy-minio:9000
S3_USE_SSL=false

